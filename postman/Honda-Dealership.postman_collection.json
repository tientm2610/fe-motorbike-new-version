    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "motorcycleId",
      "value": "",
      "type": "string"
    },
    {
      "key": "variantId",
      "value": "",
      "type": "string"
    },
    {
      "key": "imageId",
      "value": "",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string"
    },
    {
      "key": "cartItemId",
      "value": "",
      "type": "string"
    },
    {
      "key": "brandId",
      "value": "",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "javascript",
        "exec": [
          "if (pm.request.method === 'POST' || pm.request.method === 'PUT' || pm.request.method === 'DELETE') {",
          "    if (!pm.environment.get('accessToken')) {",
          "        console.log('Warning: No access token set!');",
          "    }",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "javascript",
        "exec": [
          "var jsonData = pm.response.json();",
          "pm.test('Response has code 1000', function() {",
          "    pm.expect(jsonData.code).to.eql(1000);",
          "});",
          "",
          "if (jsonData.result) {",
          "    if (jsonData.result.id) {",
          "        if (jsonData.result.motorcycleId) pm.environment.set('motorcycleId', jsonData.result.motorcycleId);",
          "        if (jsonData.result.motorcycle && jsonData.result.motorcycle.id) pm.environment.set('motorcycleId', jsonData.result.motorcycle.id);",
          "    }",
          "    if (jsonData.result.accessToken) pm.environment.set('accessToken', jsonData.result.accessToken);",
          "    if (jsonData.result.refreshToken) pm.environment.set('refreshToken', jsonData.result.refreshToken);",
          "    if (jsonData.result.id) {",
          "        if (pm.request.url.path.includes('motorcycles')) pm.environment.set('motorcycleId', jsonData.result.id);",
          "        if (pm.request.url.path.includes('variants') && !pm.request.url.path.includes('images')) pm.environment.set('variantId', jsonData.result.id);",
          "        if (pm.request.url.path.includes('variant-images') || pm.request.url.path.includes('images')) pm.environment.set('imageId', jsonData.result.id);",
          "        if (pm.request.url.path.includes('orders') && !pm.request.url.path.includes('my-orders')) pm.environment.set('orderId', jsonData.result.id);",
          "    }",
          "    if (jsonData.result.items) {",
          "        jsonData.result.items.forEach(function(item) {",
          "            if (item.motorcycleId) pm.environment.set('motorcycleId', item.motorcycleId);",
          "            if (item.variantId) pm.environment.set('variantId', item.variantId);",
          "            if (item.id && pm.request.url.path.includes('cart')) pm.environment.set('cartItemId', item.id);",
          "        });",
          "    }",
          "    if (jsonData.result.content) {",
          "        jsonData.result.content.forEach(function(item) {",
          "            if (item.id) {",
          "                if (item.motorcycleId) pm.environment.set('motorcycleId', item.motorcycleId);",
          "                if (item.variantId) pm.environment.set('variantId', item.variantId);",
          "            }",
          "        });",
          "    }",
          "}"
        ]
      }
    }
  ],
